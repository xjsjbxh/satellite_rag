# LiteLLM proxy provided by your company.
RAG_ENABLED=true
LITELLM_BASE_URL=http://api.opearlai.com:30096/v1
LITELLM_API_KEY=
LITELLM_AUTH_HEADER=x-litellm-api-key

# Chat/answer generation through LiteLLM.
LLM_BASE_URL=http://api.opearlai.com:30096/v1
LLM_API_KEY=
LLM_MODEL=
ANSWER_LLM_BASE_URL=http://api.opearlai.com:30096/v1
ANSWER_LLM_API_KEY=
ANSWER_LLM_AUTH_HEADER=x-litellm-api-key
ANSWER_LLM_MODEL=

# Embeddings through LiteLLM / OpenAI-compatible /v1/embeddings.
RAG_EMBEDDING_PROVIDER=litellm
RAG_EMBEDDING_ENDPOINT=http://api.opearlai.com:30096/v1/embeddings
RAG_EMBEDDING_API_KEY=
RAG_EMBEDDING_AUTH_HEADER=x-litellm-api-key
RAG_EMBEDDING_MODEL=Qwen3-Embedding-8B
RAG_EMBEDDING_BATCH_SIZE=16
RAG_EMBEDDING_TIMEOUT=120

# Qdrant.
RAG_VECTOR_PROVIDER=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_PATH=
QDRANT_API_KEY=
QDRANT_COLLECTION=satellite_rag
QDRANT_VECTOR_NAME=dense

# Retrieval.
RAG_KEYWORD_PROVIDER=local
RAG_RERANK_PROVIDER=litellm
RAG_VECTOR_TOP_K=30
RAG_BM25_TOP_K=30
RAG_FUSION_TOP_K=20
RAG_RERANK_TOP_K=20
RAG_FINAL_TOP_K=8
RAG_RERANK_ENDPOINT=http://api.opearlai.com:30096/v1/rerank
RAG_RERANK_AUTH_HEADER=x-litellm-api-key
RAG_RERANK_MODEL=Qwen3-Reranker-8B
RAG_RERANK_TIMEOUT=120
